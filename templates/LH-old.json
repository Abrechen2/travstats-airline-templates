{
  "airline": "Lufthansa (Buchungsdetails)",
  "iata": "LH-old",
  "version": "2025-04b",
  "from": ["@lufthansa.com", "@miles-and-more.com", "@lufthansa.de"],
  "subject": ["Buchungsdetails", "Booking details"],
  "selectors": {},
  "textPatterns": {
    "flightNumber": [
      "^([A-Z]{2}\\s+\\d{3,4})$",
      "Flugnr\\.?:\\s*([A-Z]{2}\\s?\\d{1,4})\\b"
    ],
    "pnr": [
      "(?:Buchungscode|Buchungsreferenz):\\s*([A-Z0-9]{5,8})\\b"
    ],
    "departureCode": [
      "\\d{1,2}:\\d{2}\\s+Uhr\\s+[^\\n(]+\\(([A-Z]{3})\\)"
    ],
    "arrivalCode": [
      "\\d{1,2}:\\d{2}\\s+Uhr[^\\n]+\\n[\\s\\S]+?\\d{1,2}:\\d{2}\\s+Uhr[^\\n]+\\(([A-Z]{3})\\)"
    ],
    "departureTime": [
      "[A-Za-z]{2,3}\\.\\s+(\\d{1,2}\\.?\\s+[A-Za-zÄÖÜäöü]+\\s+\\d{4})[\\s\\S]+?(\\d{1,2}:\\d{2})\\s+Uhr"
    ],
    "arrivalTime": [
      "[A-Za-z]{2,3}\\.\\s+(\\d{1,2}\\.?\\s+[A-Za-zÄÖÜäöü]+\\s+\\d{4})[\\s\\S]+?\\d{1,2}:\\d{2}\\s+Uhr[\\s\\S]+?(\\d{1,2}:\\d{2})\\s+Uhr"
    ],
    "seat": [
      "Sitzplätze:\\s*([0-9]{1,3}[A-F])",
      "Sitzplatz:\\s*([0-9]{1,3}[A-F])"
    ],
    "seatClass": [
      "Klasse:\\s*(Economy[\\w\\s]*|Business[\\w\\s]*|First[\\w\\s]*)"
    ],
    "ticketNumber": [
      "Ticketnummer:\\s*([0-9]{10,14})",
      "\\b(220[0-9]{10})\\b"
    ]
  },
  "transforms": {
    "flightNumber": "removeSpaces",
    "pnr": "uppercase",
    "departureCode": "uppercase",
    "arrivalCode": "uppercase",
    "departureTime": "parseIso",
    "arrivalTime": "parseIso"
  },
  "testCases": [
    {
      "input": "Do. 16. Januar 2025: München – Luxemburg\n07:55 Uhr\tMünchen Munich (MUC)\nTerminal 2\n09:00 Uhr\tLuxemburg Luxembourg (LUX)\nLH 2316\nLufthansa Buchungscode:\nJD4TWQ",
      "expected": {
        "flightNumber": "LH2316",
        "departureCode": "MUC",
        "arrivalCode": "LUX",
        "pnr": "JD4TWQ",
        "departureTime": "2025-01-16T07:55",
        "arrivalTime": "2025-01-16T09:00"
      }
    }
  ]
}
